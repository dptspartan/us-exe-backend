# Copy to `.env.dev` and `.env.prod`, then fill secrets from:
# Dashboard → Project Settings → API (service role)
# Dashboard → Project Settings → Database (password, for `supabase link`)

SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password

# Optional — edge functions use this for reliable Expo push delivery
EXPO_ACCESS_TOKEN=

# Required for E2EE — unique per dev/prod Supabase project (32+ char random secret)
E2EE_MASTER_KEY=
